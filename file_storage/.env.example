FILE_STORAGE_APP_NAME=Model Storage
FILE_STORAGE_API_HOST=0.0.0.0
FILE_STORAGE_API_PORT=8080
FILE_STORAGE_API_KEY=<long-random-value>
FILE_STORAGE_PREVIOUS_API_KEY=
FILE_STORAGE_CORS_ALLOW_ORIGINS=["https://prodcast.company.local"]
FILE_STORAGE_ENABLE_UI=false
FILE_STORAGE_ENABLE_API_DOCS=false
FILE_STORAGE_DB_HOST=postgresql.internal
FILE_STORAGE_DB_PORT=5432
FILE_STORAGE_DB_USER=<model-storage-db-user>
FILE_STORAGE_DB_PASSWORD=<strong-model-storage-db-password>
FILE_STORAGE_DB_NAME=file-storage
FILE_STORAGE_DB_SSL_MODE=require
FILE_STORAGE_STORAGE_DIR=./files
FILE_STORAGE_MAX_UPLOAD_BYTES=262144000
FILE_STORAGE_MAX_ZIP_FILES=5000
FILE_STORAGE_MAX_ZIP_UNCOMPRESSED_BYTES=2147483648
FILE_STORAGE_MAX_ZIP_COMPRESSION_RATIO=100
FILE_STORAGE_STREAM_CHUNK_BYTES=1048576
FILE_STORAGE_GATEWAY_BIND=0.0.0.0
FILE_STORAGE_GATEWAY_PORT=8080
FILE_STORAGE_ACCEL_REDIRECT_ENABLED=true
FILE_STORAGE_ACCEL_REDIRECT_PREFIX=/internal-model-storage/
